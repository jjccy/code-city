{
  "name": "code-city",
  "displayName": "Code City",
  "description": "An idle dev civilization — feed pets with your typing, build a city as you code.",
  "version": "0.1.0",
  "publisher": "jjccy",
  "repository": {
    "type": "git",
    "url": "https://github.com/jjccy/code-city"
  },
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "type": "webview",
          "id": "code-city.gameView",
          "name": "Code City",
          "icon": "media/icon.svg"
        }
      ]
    },
    "commands": [
      { "command": "code-city.addPet",         "title": "Code City: Add Pet" },
      { "command": "code-city.collectResources","title": "Code City: Collect Resources" },
      { "command": "code-city.openPanel",       "title": "Code City: Open Panel" }
    ],
    "configuration": {
      "title": "Code City",
      "properties": {
        "code-city.llmInsertThreshold": {
          "type": "number",
          "default": 8,
          "description": "Characters inserted in one event above this = LLM feed (not manual)."
        },
        "code-city.charsPerNormalFeed": {
          "type": "number",
          "default": 200,
          "description": "LLM characters needed to produce 1 normal feed."
        },
        "code-city.charsPerPremiumFeed": {
          "type": "number",
          "default": 100,
          "description": "Manual characters needed to produce 1 premium feed."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
